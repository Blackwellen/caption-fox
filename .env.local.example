# ── Supabase (REQUIRED) ─────────────────────────────────────────────
# Without these the middleware throws and every route returns 500.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── App (REQUIRED in production) ────────────────────────────────────
# Public base URL of the deployment. Used for auth redirects / links.
# Local: http://localhost:3004   Production: https://caption-fox.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3004

# ── AI (REQUIRED for AI features) ───────────────────────────────────
# Used by /api/ai/generate, /api/ai/chat, /api/ai/image.
# Get one at https://console.anthropic.com — without it AI routes 500.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Optional ────────────────────────────────────────────────────────
# Stability AI key for image generation in /api/ai/image (falls back if absent).
STABILITY_API_KEY=

# Supabase CLI personal access token (LOCAL TOOLING ONLY — do NOT add to Vercel).
SUPABASE_ACCESS_TOKEN=
